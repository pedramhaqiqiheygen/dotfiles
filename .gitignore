# Ignore everything by default (whitelist approach for dotfiles)
*

# Shell config
!.zshrc
!.zshenv
!.aliases.zsh

# Git config
!.gitconfig
!.gitignore

# Config directory structure
!.config/
!.config/nvim/
!.config/nvim/**
!.config/tmux/
!.config/tmux/**
!.config/starship.toml

# SSH config — tracked as a TEMPLATE (real ~/.ssh/config stays untracked).
# Copy ~/.ssh/config.example to ~/.ssh/config on a new machine and fill in
# real HostName / User / IdentityFile values. (Keys protected by *.pem / *.key.)
!.ssh/
!.ssh/config.example

# Shareable dotfiles docs (docs/specs/ and docs/plans/ stay private).
!docs/
!docs/dotfiles/
!docs/dotfiles/**

# Sensitive - never track
.config/gh/
**/hosts.json
**/*.pem
**/*.key
.env*
