# SSH config template for the dev command center.
# Copy to ~/.ssh/config and fill in HostName / User / IdentityFile per host.
#
#   cp ~/.ssh/config.example ~/.ssh/config
#   chmod 600 ~/.ssh/config
#
# Each Host alias here should match a `ssh_host` entry in
# ~/.config/dev/machines.conf so `dev <machine>` resolves correctly.

# Tighter keepalive + ControlMaster multiplexing for hosts used by dev.
# (Faster reconnect after sleep; persistent control socket for 10 min.)
Host nebius devbox
  ServerAliveInterval 15
  ServerAliveCountMax 3
  TCPKeepAlive yes
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m

# Defaults for everything else
Host *
  ServerAliveInterval 30
  ServerAliveCountMax 5
  TCPKeepAlive yes

# --- Example host blocks ----------------------------------------------------
# Replace HostName with the real host (or IP) for each machine you care about,
# and replace User with your remote username. IdentityFile is optional.

Host prodai
  HostName REPLACE_WITH_HOSTNAME
  User REPLACE_WITH_USER

Host nebius
  HostName REPLACE_WITH_HOSTNAME
  User REPLACE_WITH_USER

Host devbox
  HostName REPLACE_WITH_HOSTNAME
  User REPLACE_WITH_USER
  # IdentityFile ~/.ssh/your-key.pem

Host h200
  HostName REPLACE_WITH_HOSTNAME
  User REPLACE_WITH_USER

# GitHub (typical macOS setup)
Host github.com
  HostName github.com
  User git
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
