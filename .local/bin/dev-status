#!/usr/bin/env bash
# dev-status — render the v2 status bar.
# Subcommands:
#   bar              # whole bar: focused row + pills + prefix chip + clock
#   row <machine>    # focused-row tab list with click ranges
#   pill <machine>   # one peer pill
#   status-bullet <m>  # back-compat with v1 status-format[N]; deprecated
set -u
source ~/.local/bin/dev-lib.sh

# --- Palette ---
BG="#0B0E14"
FG="#BFBDB6"
FG_DIM="#7a818d"
FG_NUM="#475266"
FG_SEP="#2a313d"
ACCENT="#95E6CB"
ACCENT_BG="#1a2433"
OK="#a6e3a1"
ERR="#f38ba8"
PILL_BG="#13171f"
PILL_ERR_BG="#221318"

CACHE_DIR=/tmp/dev-status-cache
mkdir -p "$CACHE_DIR" 2>/dev/null

# Background refresh helper (existing pattern from v1).
# Spawns "$@" in background if cached output for "$key" is older than $ttl seconds.
_bg_refresh() {
  local key="$1" ttl="$2"; shift 2
  local f="$CACHE_DIR/$key"
  if [[ -f "$f" ]] && (( $(date +%s) - $(stat -f %m "$f" 2>/dev/null || echo 0) < ttl )); then
    return
  fi
  ( "$@" > "$f.tmp" 2>/dev/null && mv "$f.tmp" "$f" ) &
}

_machine_healthy() {
  local m="$1"
  # If the host has any open window, assume healthy. (Future Layer 3 health-cache integration TBD.)
  local windows
  windows=$(dev_lib::windows_for "$m" | wc -l | tr -d ' ')
  (( windows > 0 ))
}

# --- Subcommand: row <machine> ---
# Renders: bullet + label + │ + clickable tabs + (if focused row) + spawn affordance
row() {
  local m="$1"
  local active_m
  active_m=$(dev_lib::active_machine)
  local color
  color=$(dev_lib::machine_color "$m" 2>/dev/null)
  [[ -z "$color" ]] && color="$FG"
  local label_text
  case "$m" in
    gpu)   label_text="󰢮 GPU" ;;
    aws)   label_text="󰅟 AWS" ;;
    local) label_text="󰆍 HOME" ;;
    *)     label_text="$(dev_lib::machine_icon "$m") $(echo "$m" | tr '[:lower:]' '[:upper:]')" ;;
  esac

  local bullet bullet_color
  if _machine_healthy "$m"; then
    bullet="●"; bullet_color="$color"
  else
    bullet="●"; bullet_color="$ERR"
  fi

  # Header: bullet + label + separator
  printf '#[fg=%s]%s#[default] #[fg=%s,bold]%s#[default] #[fg=%s]│#[default]' \
    "$bullet_color" "$bullet" "$color" "$label_text" "$FG_SEP"

  # Current window index (for active-tab highlight)
  local current_idx
  current_idx=$(tmux display-message -p '#{window_index}' 2>/dev/null)

  # Tabs
  local n=0
  local rendered=""
  while IFS='|' read -r gidx name; do
    n=$((n + 1))
    local truncated
    truncated=$(dev_lib::truncate "$name" 22)
    if [[ "$gidx" == "$current_idx" ]]; then
      rendered+=$(printf '  #[range=user|%s]#[fg=%s]%d#[default] #[fg=%s,bold]%s#[default]#[norange]' \
        "$gidx" "$FG_NUM" "$n" "$ACCENT" "$truncated")
    else
      rendered+=$(printf '  #[range=user|%s]#[fg=%s]%d#[default] #[fg=%s]%s#[default]#[norange]' \
        "$gidx" "$FG_NUM" "$n" "$FG_DIM" "$truncated")
    fi
  done < <(dev_lib::windows_for "$m")

  printf '%s' "$rendered"

  # + spawn affordance (only on focused row)
  if [[ "$m" == "$active_m" ]]; then
    printf '  #[range=user|+]#[fg=%s]+#[default]#[norange]' "$FG_NUM"
  fi
}

# --- Subcommand: pill <machine> ---
pill() {
  local m="$1"
  local color count bullet_color bg
  color=$(dev_lib::machine_color "$m" 2>/dev/null)
  count=$(dev_lib::windows_for "$m" | wc -l | tr -d ' ')
  if _machine_healthy "$m"; then
    bullet_color="$color"
    bg="$PILL_BG"
  else
    bullet_color="$ERR"
    bg="$PILL_ERR_BG"
  fi
  local label_text
  case "$m" in
    gpu)   label_text="GPU" ;;
    aws)   label_text="AWS" ;;
    local) label_text="HOME" ;;
    *)     label_text=$(echo "$m" | tr '[:lower:]' '[:upper:]') ;;
  esac
  printf '#[range=pill|%s]#[bg=%s,fg=%s] ●#[fg=%s] %s#[fg=%s] %d #[default]#[norange]' \
    "$m" "$bg" "$bullet_color" "$color" "$label_text" "$FG_NUM" "$count"
}

# --- Subcommand: bar ---
bar() {
  local active_m
  active_m=$(dev_lib::active_machine)

  # Focused row
  row "$active_m"

  # Right-align: pills + prefix chip + clock
  printf '#[align=right]'

  # Peer pills (every machine except active, in declared order; "local" always last)
  local peers=()
  while IFS= read -r m; do
    [[ "$m" == "$active_m" ]] && continue
    peers+=("$m")
  done < <(dev_lib::machines)
  if [[ "$active_m" != "local" ]]; then
    peers+=("local")
  fi
  for m in "${peers[@]}"; do
    pill "$m"
    printf ' '
  done

  # Prefix chip (C-a / C-b / jump-table indicator)
  local chip=""
  if [[ "$(tmux display-message -p '#{client_prefix}' 2>/dev/null)" == "1" ]]; then
    chip="C-a"
  elif [[ "$(tmux show-options -gqv @remote_prefix 2>/dev/null)" == "1" ]]; then
    chip="C-b"
  fi
  if [[ -n "$chip" ]]; then
    printf '#[bg=%s,fg=%s] %s #[default]' "$ACCENT_BG" "$ACCENT" "$chip"
  else
    printf '#[fg=%s]%s ' "$FG_NUM" "$(date +%H:%M)"
  fi
}

# Back-compat: legacy `dev-status <machine>` rendered ONLY the tab list
# (v1 status-format had bullet+label as literals). Don't fall through to row()
# or the bullet+label will double up while the v1 status conf is still active.
tabs_only() {
  local m="$1"
  local current_idx
  current_idx=$(tmux display-message -p '#{window_index}' 2>/dev/null)
  local n=0
  while IFS='|' read -r gidx name; do
    n=$((n + 1))
    local truncated
    truncated=$(dev_lib::truncate "$name" 22)
    if [[ "$gidx" == "$current_idx" ]]; then
      printf '  #[range=user|%s]#[fg=%s]%d#[default] #[fg=%s,bold]%s#[default]#[norange]' \
        "$gidx" "$FG_NUM" "$n" "$ACCENT" "$truncated"
    else
      printf '  #[range=user|%s]#[fg=%s]%d#[default] #[fg=%s]%s#[default]#[norange]' \
        "$gidx" "$FG_NUM" "$n" "$FG_DIM" "$truncated"
    fi
  done < <(dev_lib::windows_for "$m")
}

# Back-compat: keep status-bullet so v1 tmux-status.conf doesn't crash during transition.
status_bullet() {
  local m="$1"
  local color bullet
  color=$(dev_lib::machine_color "$m" 2>/dev/null)
  [[ -z "$color" ]] && color="$FG"
  if _machine_healthy "$m"; then
    printf '#[fg=%s]●#[default]' "$color"
  else
    printf '#[fg=%s]●#[default]' "$ERR"
  fi
}

case "${1:-bar}" in
  bar)            bar ;;
  row)            row "${2:-local}" ;;
  pill)           pill "${2:-local}" ;;
  status-bullet)  status_bullet "${2:-local}" ;;
  *)              # Legacy v1: dev-status <machine> emitted only tab list
                  tabs_only "$1" ;;
esac
