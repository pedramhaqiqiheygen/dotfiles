#!/usr/bin/env bash
# dev-jump <machine> <per-row-idx>
# Selects the Nth window where @dev_machine matches.

set -u
source ~/.local/bin/dev-lib.sh

machine="${1:-}"
idx="${2:-}"
[[ -n "$machine" ]] || exit 0
[[ "$idx" =~ ^[1-9][0-9]*$ ]] || exit 0

n=0
while IFS='|' read -r global_idx _name; do
  n=$((n + 1))
  if (( n == idx )); then
    tmux select-window -t "$global_idx"
    exit 0
  fi
done < <(dev_lib::windows_for "$machine")
