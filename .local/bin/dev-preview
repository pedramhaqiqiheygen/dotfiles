#!/usr/bin/env bash
# dev-preview <per-row-idx>
# Shows a popup with the last 50 lines of the Nth tab in the focused machine's row.
# Does NOT switch focus — peek without leaving your current window.

set -u

CONF_FILE="$HOME/.config/dev/machines.conf"

idx="${1:-}"
[[ "$idx" =~ ^[1-9][0-9]*$ ]] || exit 0

# Determine current machine
current_name=$(tmux display-message -p '#{window_name}' 2>/dev/null) || exit 0
machine="local"
if [[ -f "$CONF_FILE" ]]; then
  while IFS= read -r p; do
    [[ -z "$p" ]] && continue
    if [[ "$current_name" == "${p}:"* ]]; then
      machine="$p"
      break
    fi
  done < <(grep -v '^#' "$CONF_FILE" | grep -v '^$' | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $1); print $1}')
fi

# Resolve Nth window in that row → global idx
prefixes=()
if [[ -f "$CONF_FILE" ]]; then
  mapfile -t prefixes < <(grep -v '^#' "$CONF_FILE" | grep -v '^$' | awk -F'|' '{gsub(/^[ \t]+|[ \t]+$/, "", $1); print $1}')
fi

target_global_idx=""
n=0
while IFS='|' read -r global_idx name; do
  if [[ "$machine" == "local" ]]; then
    skip=false
    for p in "${prefixes[@]}"; do
      [[ "$name" == ${p}:* ]] && skip=true && break
    done
    [[ "$skip" == true ]] && continue
  else
    [[ "$name" != ${machine}:* ]] && continue
  fi
  n=$((n + 1))
  if [[ "$n" -eq "$idx" ]]; then
    target_global_idx="$global_idx"
    break
  fi
done < <(tmux list-windows -F '#{window_index}|#{window_name}' 2>/dev/null)

[[ -z "$target_global_idx" ]] && exit 0

tmux display-popup -w 80% -h 60% -E \
  "tmux capture-pane -p -t '$target_global_idx' -S -50 | less +G" 2>/dev/null
