#!/usr/bin/env bash
# dev-click <row> <action> <mouse_x>
# Resolves a mouse-on-status click against the clickmap file for <row>
# and performs <action> on the matching window.
#
# Actions:
#   select  -> tmux select-window -t <idx>
#   kill    -> tmux kill-window -t <idx>
#   preview -> tmux display-popup -E "tmux capture-pane -p -t <idx> -S -50 | less +G"
#
# Silently no-ops on missing clickmap, no-match, or unknown action.

set -u

CACHE_DIR="/tmp/dev-status-cache"
PREFIX_OFFSET="${DEV_CLICK_PREFIX_OFFSET:-9}"  # static prefix width: " ● gpu  " etc.

row="${1:-}"
action="${2:-}"
mouse_x="${3:-}"

# Validate args
[[ "$row"     =~ ^[0-9]+$ ]] || exit 0
[[ -n "$action" ]] || exit 0
[[ "$mouse_x" =~ ^[0-9]+$ ]] || exit 0

clickmap="$CACHE_DIR/clickmap-${row}"
[[ -f "$clickmap" ]] || exit 0

# Local x relative to where dev-status output starts (after the prefix the
# tmux status-format string draws). If the click is left of the prefix, no-op.
local_x=$((mouse_x - PREFIX_OFFSET))
[[ "$local_x" -lt 0 ]] && exit 0

# Find matching record
target_idx=""
while IFS='|' read -r start_col end_col widx; do
  if [[ "$local_x" -ge "$start_col" && "$local_x" -lt "$end_col" ]]; then
    target_idx="$widx"
    break
  fi
done < "$clickmap"

[[ -z "$target_idx" ]] && exit 0

case "$action" in
  select)
    tmux select-window -t "$target_idx" 2>/dev/null
    ;;
  kill)
    tmux kill-window -t "$target_idx" 2>/dev/null
    ;;
  preview)
    tmux display-popup -w 80% -h 60% -E \
      "tmux capture-pane -p -t '$target_idx' -S -50 | less +G" 2>/dev/null
    ;;
  *)
    exit 0
    ;;
esac
