#!/usr/bin/env bash
# dev-click <action> <window_idx>
# Performs <action> on window <window_idx>. The window idx is resolved by
# tmux via #{mouse_status_range} on a #[range=user|<idx>] in the status
# format — this script only dispatches.
#
# Actions:
#   select  -> tmux select-window -t <idx>
#   kill    -> tmux kill-window -t <idx>
#   preview -> tmux display-popup -E "tmux capture-pane -p -t <idx> -S -50 | less +G"
#
# Silently no-ops on missing args, non-numeric idx, or unknown action.

set -u

action="${1:-}"
target_idx="${2:-}"

[[ -n "$action" ]] || exit 0
# tmux passes empty string when click was outside any range — silently no-op.
[[ -n "$target_idx" ]] || exit 0
[[ "$target_idx" =~ ^[0-9]+$ ]] || exit 0

case "$action" in
  select)
    tmux select-window -t "$target_idx" 2>/dev/null
    ;;
  kill)
    tmux kill-window -t "$target_idx" 2>/dev/null
    ;;
  preview)
    tmux display-popup -w 80% -h 60% -E \
      "tmux capture-pane -p -t '$target_idx' -S -50 | less +G" 2>/dev/null
    ;;
  *)
    exit 0
    ;;
esac
